rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Components Catalog: Public read for Client SDK (e.g., /build page UI), No writes
    match /components/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Builds: Secure access explicitly to the authenticated owner
    match /builds/{buildId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Default lockdown for everything else (users, telemetry, analytics handled securely via Admin SDK)
    match /{document=**} {  
      allow read, write: if false;
    }
  }
}
